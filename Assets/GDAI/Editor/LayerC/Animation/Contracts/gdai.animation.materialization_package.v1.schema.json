{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "gdai.animation.materialization_package.v1",
  "title": "GDAI animation materialization package v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "package_class", "package_id", "package_content_sha256", "profile_id", "entity_id", "adoption", "qa", "provider_provenance", "sheet", "import_policy", "clips", "cells", "normalization", "materialization_target"],
  "properties": {
    "schema": { "const": "gdai.animation.materialization_package.v1" },
    "package_class": { "enum": ["TEST_ONLY", "PRODUCTION"] },
    "package_id": { "type": "string", "minLength": 1 },
    "package_content_sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "profile_id": { "type": "string", "minLength": 1 },
    "profile_version": { "type": "integer", "minimum": 1 },
    "entity_id": { "type": "string", "minLength": 1 },
    "adoption": {
      "type": "object",
      "additionalProperties": false,
      "required": ["adoption_event_id", "adopted", "revoked"],
      "properties": {
        "adoption_event_id": { "type": ["string", "null"] },
        "adopted": { "type": "boolean" },
        "revoked": { "type": "boolean" },
        "adopted_at": { "type": ["string", "null"] },
        "source_generation_event_id": { "type": ["string", "null"] }
      }
    },
    "qa": {
      "type": "object",
      "additionalProperties": false,
      "required": ["qa_event_id", "status", "gate_version"],
      "properties": {
        "qa_event_id": { "type": ["string", "null"] },
        "status": { "enum": ["PASSED", "FAILED", "PENDING"] },
        "gate_version": { "type": "string" }
      }
    },
    "provider_provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["provider_id", "request_digest", "capability_status", "license_status"],
      "properties": {
        "provider_id": { "type": "string" },
        "request_digest": { "type": ["string", "null"] },
        "capability_status": { "type": "string" },
        "license_status": { "enum": ["CLEARED", "UNKNOWN", "BLOCKED"] }
      }
    },
    "sheet": {
      "type": "object",
      "additionalProperties": false,
      "required": ["role", "content_sha256", "cell_width", "cell_height", "columns", "rows", "alpha"],
      "properties": {
        "role": { "const": "RAW_SPRITE_SHEET" },
        "content_sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
        "cell_width": { "type": "integer", "minimum": 1 },
        "cell_height": { "type": "integer", "minimum": 1 },
        "columns": { "type": "integer", "minimum": 1 },
        "rows": { "type": "integer", "minimum": 1 },
        "alpha": { "enum": ["STRAIGHT", "PREMULTIPLIED", "UNKNOWN"] }
      }
    },
    "import_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["pixels_per_unit", "pivot", "filter_mode", "nominal_fps"],
      "properties": {
        "pixels_per_unit": { "type": "number", "exclusiveMinimum": 0 },
        "pivot": {
          "type": "object",
          "additionalProperties": false,
          "required": ["alignment", "x", "y"],
          "properties": {
            "alignment": { "enum": ["Center", "Custom", "BottomCenter"] },
            "x": { "type": "number" },
            "y": { "type": "number" }
          }
        },
        "filter_mode": { "enum": ["Point", "Bilinear"] },
        "nominal_fps": { "type": "number", "exclusiveMinimum": 0 }
      }
    },
    "clips": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["clip_id", "action", "direction", "frame_count", "nominal_fps", "loop", "events"],
        "properties": {
          "clip_id": { "type": "string", "pattern": "^[A-Za-z0-9_]+$" },
          "action": { "type": "string" },
          "direction": { "type": ["string", "null"] },
          "frame_count": { "type": "integer", "minimum": 1 },
          "nominal_fps": { "type": "number", "exclusiveMinimum": 0 },
          "loop": { "type": "boolean" },
          "pivot": { "type": ["object", "null"] },
          "events": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["kind", "frame_index", "semantic", "cancel_on_interrupt"],
              "properties": {
                "kind": { "enum": ["HIT", "AUDIO", "VFX"] },
                "frame_index": { "type": "integer", "minimum": 0 },
                "semantic": { "enum": ["OPEN", "CLOSE", "POINT"] },
                "cancel_on_interrupt": { "const": true },
                "payload_ref": { "type": ["string", "null"] }
              }
            }
          }
        }
      }
    },
    "cells": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["cell_id", "sprite_name", "clip_id", "frame_index", "direction", "row", "column"],
        "properties": {
          "cell_id": { "type": "string", "pattern": "^[A-Za-z0-9_.]+$" },
          "sprite_name": { "type": "string", "pattern": "^GDAI__[A-Za-z0-9_]+$" },
          "clip_id": { "type": "string", "pattern": "^[A-Za-z0-9_]+$" },
          "frame_index": { "type": "integer", "minimum": 0 },
          "direction": { "type": ["string", "null"] },
          "row": { "type": "integer", "minimum": 0 },
          "column": { "type": "integer", "minimum": 0 }
        }
      }
    },
    "normalization": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source_schema", "source_package_id", "source_axis_origin", "adapter_version", "axis_convention"],
      "properties": {
        "source_schema": { "type": "string" },
        "source_package_id": { "type": "string" },
        "source_axis_origin": { "enum": ["TOP_LEFT", "BOTTOM_LEFT"] },
        "adapter_version": { "type": "string" },
        "axis_convention": { "const": "CANONICAL_ROW_MAJOR" },
        "notes": { "type": "string" }
      }
    },
    "materialization_target": {
      "type": "object",
      "additionalProperties": false,
      "required": ["root", "sprites_dir", "clips_dir", "controllers_dir", "ownership_label"],
      "properties": {
        "root": { "const": "Assets/GDAI_Project/Generated/Animations" },
        "sprites_dir": { "const": "Sprites" },
        "clips_dir": { "const": "Clips" },
        "controllers_dir": { "const": "Controllers" },
        "ownership_label": { "const": "GDAI_Owned_Animation" }
      }
    }
  }
}
